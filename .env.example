# WICHTIG: Kopiere diese Datei zu .env und fülle die Werte aus!

# Anthropic API Key (für Claude KI-Analysen)
# Hole deinen Key von: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Gmail Einstellungen (für Email-Versand)
# ACHTUNG: Du brauchst ein App-Passwort, NICHT dein echtes Gmail-Passwort!
# Siehe: https://support.google.com/accounts/answer/185833
SENDER_EMAIL=deine-email@gmail.com
SENDER_PASSWORD=dein-app-passwort
